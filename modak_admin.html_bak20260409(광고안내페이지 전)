<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MODAK Admin</title>
<link href="https://fonts.googleapis.com/css2?family=Pretendard:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --bg:       #F4F5F7;
  --card:     #FFFFFF;
  --side:     #0F1623;
  --side2:    #1A2235;
  --side-act: #1E6FFF;
  --side-txt: #8896A8;
  --side-ht:  #FFFFFF;
  --pri:      #1E6FFF;
  --pri-lt:   #EBF2FF;
  --pri-dk:   #1455CC;
  --grn:      #12B76A;
  --grn-lt:   #ECFDF5;
  --red:      #F04438;
  --red-lt:   #FEF3F2;
  --amb:      #F79009;
  --amb-lt:   #FFFAEB;
  --pur:      #7C3AED;
  --pur-lt:   #F5F3FF;
  --txt1:     #101828;
  --txt2:     #475467;
  --txt3:     #98A2B3;
  --bd:       #EAECF0;
  --side-w:   240px;
  --hdr-h:    60px;
  --r:        10px;
  --r-sm:     6px;
}


/* ── 로그인 화면 ── */
.login-screen {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  width: 100vw; height: 100vh;
  background: #0F1623;
  display: flex; align-items: center; justify-content: center;
  z-index: 999999;
  flex-direction: column;
  margin: 0; padding: 0;
}
.login-card {
  background: #1A2235;
  border: 1px solid rgba(255,255,255,.08);
  border-radius: 20px;
  padding: 40px 36px;
  width: 380px;
  max-width: calc(100vw - 40px);
  box-sizing: border-box;
  display: flex; flex-direction: column; gap: 0;
}
.login-logo {
  width: 52px; height: 52px;
  background: var(--pri);
  border-radius: 14px;
  display: flex; align-items: center; justify-content: center;
  font-size: 24px; font-weight: 800; color: #fff;
  margin: 0 auto 20px;
}
.login-title { font-size: 22px; font-weight: 800; color: #fff; text-align: center; margin-bottom: 6px; }
.login-sub   { font-size: 13px; color: #8896A8; text-align: center; margin-bottom: 28px; }
.login-label { font-size: 12px; font-weight: 600; color: #8896A8; margin-bottom: 6px; }
.login-input {
  width: 100%; background: rgba(255,255,255,.06);
  border: 1px solid rgba(255,255,255,.1);
  border-radius: 10px; padding: 11px 14px;
  font-size: 14px; color: #fff; font-family: inherit;
  outline: none; transition: border .15s; margin-bottom: 14px;
}
.login-input:focus { border-color: var(--pri); background: rgba(30,111,255,.1); }
.login-input::placeholder { color: rgba(255,255,255,.25); }
.login-btn {
  width: 100%; padding: 12px;
  background: var(--pri); color: #fff;
  border: none; border-radius: 10px;
  font-size: 14px; font-weight: 700;
  cursor: pointer; margin-top: 4px;
  transition: opacity .15s; font-family: inherit;
}
.login-btn:hover { opacity: .9; }
.login-err { font-size: 12px; color: var(--red); text-align: center; margin-top: 8px; min-height: 18px; }
.login-footer { font-size: 11px; color: rgba(255,255,255,.25); text-align: center; margin-top: 20px; }

/* ── 사이드바 하단 로그인 상태 ── */
.side-user-wrap { padding: 10px 8px 6px; border-top: 1px solid rgba(255,255,255,.06); }
.side-user-card {
  display: flex; align-items: center; gap: 10px;
  padding: 10px 12px; border-radius: 8px;
  cursor: pointer; transition: background .15s;
}
.side-user-card:hover { background: rgba(255,255,255,.06); }
.side-logout-btn {
  display: flex; align-items: center; gap: 8px;
  padding: 8px 12px; border-radius: 8px;
  cursor: pointer; transition: background .15s;
  color: rgba(240,68,56,.7); font-size: 12px; font-weight: 600;
  margin-top: 2px;
}
.side-logout-btn:hover { background: rgba(240,68,56,.1); color: var(--red); }

body {
  font-family: 'Pretendard', -apple-system, sans-serif;
  background: var(--bg);
  color: var(--txt1);
  display: flex;
  min-height: 100vh;
  font-size: 14px;
}

/* ── 사이드바 ── */
.sidebar {
  width: var(--side-w);
  background: var(--side);
  position: fixed;
  top: 0; left: 0; bottom: 0;
  display: flex;
  flex-direction: column;
  z-index: 100;
  transition: width .2s;
}

.side-logo {
  height: var(--hdr-h);
  display: flex;
  align-items: center;
  padding: 0 20px;
  border-bottom: 1px solid rgba(255,255,255,.06);
  gap: 10px;
  text-decoration: none;
}
.side-logo-mark {
  width: 32px; height: 32px;
  background: var(--pri);
  border-radius: 8px;
  display: flex; align-items: center; justify-content: center;
  font-size: 15px; font-weight: 800;
  color: #fff;
  letter-spacing: -1px;
  flex-shrink: 0;
}
.side-logo-text {
  font-size: 16px; font-weight: 700;
  color: #fff;
  letter-spacing: -0.3px;
}
.side-logo-badge {
  font-size: 9px; font-weight: 600;
  color: var(--pri);
  background: rgba(30,111,255,.15);
  padding: 2px 6px;
  border-radius: 4px;
  margin-left: auto;
}

.side-nav {
  flex: 1;
  overflow-y: auto;
  padding: 12px 0;
  scrollbar-width: none;
}
.side-nav::-webkit-scrollbar { display: none; }

.side-section-label {
  font-size: 10px;
  font-weight: 600;
  color: rgba(136,150,168,.5);
  letter-spacing: 0.8px;
  text-transform: uppercase;
  padding: 12px 20px 4px;
}

.nav-item {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 9px 20px;
  cursor: pointer;
  color: var(--side-txt);
  font-size: 13.5px;
  font-weight: 500;
  border-radius: 0;
  transition: all .15s;
  position: relative;
  text-decoration: none;
  user-select: none;
  margin: 1px 8px;
  border-radius: 8px;
}
.nav-item:hover {
  background: rgba(255,255,255,.06);
  color: #fff;
}
.nav-item.active {
  background: rgba(30,111,255,.18);
  color: #fff;
}
.nav-item.active::before {
  content: '';
  position: absolute;
  left: -8px; top: 50%;
  transform: translateY(-50%);
  width: 3px; height: 20px;
  background: var(--pri);
  border-radius: 0 3px 3px 0;
}
.nav-icon {
  width: 18px; height: 18px;
  flex-shrink: 0;
  opacity: .7;
}
.nav-item.active .nav-icon,
.nav-item:hover .nav-icon { opacity: 1; }
.nav-badge {
  margin-left: auto;
  font-size: 10px;
  font-weight: 700;
  padding: 2px 6px;
  border-radius: 10px;
  background: var(--red);
  color: #fff;
  min-width: 18px;
  text-align: center;
}
.nav-badge.amber { background: var(--amb); }

.side-bottom {
  padding: 12px 8px;
  border-top: 1px solid rgba(255,255,255,.06);
}
.admin-profile {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px 12px;
  border-radius: 8px;
  cursor: pointer;
  transition: background .15s;
}
.admin-profile:hover { background: rgba(255,255,255,.06); }
.admin-av {
  width: 32px; height: 32px;
  border-radius: 50%;
  background: linear-gradient(135deg, #1E6FFF, #7C3AED);
  display: flex; align-items: center; justify-content: center;
  font-size: 12px; font-weight: 700;
  color: #fff;
  flex-shrink: 0;
}
.admin-name { font-size: 13px; font-weight: 600; color: #fff; }
.admin-role { font-size: 11px; color: var(--side-txt); }

/* ── 메인 영역 ── */
.main {
  margin-left: var(--side-w);
  flex: 1;
  display: flex;
  flex-direction: column;
  min-height: 100vh;
}

/* ── 헤더 ── */
.header {
  height: var(--hdr-h);
  background: var(--card);
  border-bottom: 1px solid var(--bd);
  display: flex;
  align-items: center;
  padding: 0 24px;
  gap: 16px;
  position: sticky;
  top: 0;
  z-index: 50;
}
.header-title {
  font-size: 16px;
  font-weight: 700;
  color: var(--txt1);
}
.header-breadcrumb {
  font-size: 12px;
  color: var(--txt3);
  display: flex;
  align-items: center;
  gap: 6px;
  margin-left: 4px;
}
.header-search {
  margin-left: auto;
  display: flex;
  align-items: center;
  gap: 8px;
  background: var(--bg);
  border: 1px solid var(--bd);
  border-radius: var(--r-sm);
  padding: 7px 12px;
  width: 220px;
  color: var(--txt3);
  font-size: 13px;
  cursor: text;
}
.header-actions {
  display: flex;
  align-items: center;
  gap: 8px;
}
.icon-btn {
  width: 36px; height: 36px;
  border-radius: var(--r-sm);
  border: 1px solid var(--bd);
  background: transparent;
  display: flex; align-items: center; justify-content: center;
  cursor: pointer;
  color: var(--txt2);
  position: relative;
  transition: all .15s;
}
.icon-btn:hover { background: var(--bg); }
.notif-dot {
  position: absolute;
  top: 6px; right: 7px;
  width: 7px; height: 7px;
  background: var(--red);
  border-radius: 50%;
  border: 2px solid var(--card);
}

/* ── 콘텐츠 ── */
.content {
  flex: 1;
  padding: 24px;
}

/* ── KPI 카드 ── */
.kpi-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16px;
  margin-bottom: 24px;
}
.kpi-card {
  background: var(--card);
  border-radius: var(--r);
  padding: 20px;
  border: 1px solid var(--bd);
  display: flex;
  flex-direction: column;
  gap: 12px;
  transition: box-shadow .15s;
}
.kpi-card:hover { box-shadow: 0 2px 12px rgba(0,0,0,.07); }
.kpi-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.kpi-label {
  font-size: 13px;
  font-weight: 500;
  color: var(--txt2);
}
.kpi-icon {
  width: 36px; height: 36px;
  border-radius: 8px;
  display: flex; align-items: center; justify-content: center;
}
.kpi-num {
  font-size: 28px;
  font-weight: 700;
  color: var(--txt1);
  letter-spacing: -0.5px;
  line-height: 1;
}
.kpi-change {
  font-size: 12px;
  font-weight: 500;
  display: flex;
  align-items: center;
  gap: 4px;
}
.kpi-change.up { color: var(--grn); }
.kpi-change.dn { color: var(--red); }
.kpi-change.warn { color: var(--amb); }

/* ── 그리드 레이아웃 ── */
.dash-grid {
  display: grid;
  grid-template-columns: 1fr 340px;
  gap: 16px;
  margin-bottom: 24px;
}

/* ── 섹션 카드 ── */
.section-card {
  background: var(--card);
  border-radius: var(--r);
  border: 1px solid var(--bd);
  overflow: hidden;
}
.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px 20px;
  border-bottom: 1px solid var(--bd);
}
.section-title {
  font-size: 14px;
  font-weight: 700;
  color: var(--txt1);
}
.section-action {
  font-size: 12px;
  color: var(--pri);
  font-weight: 600;
  cursor: pointer;
  padding: 4px 10px;
  border-radius: var(--r-sm);
  transition: background .15s;
}
.section-action:hover { background: var(--pri-lt); }

/* ── 신고 목록 ── */
.report-list { padding: 0; }
.report-item {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px 20px;
  border-bottom: 1px solid var(--bd);
  cursor: pointer;
  transition: background .12s;
}
.report-item:last-child { border-bottom: none; }
.report-item:hover { background: #FAFAFA; }
.report-sev {
  width: 8px; height: 8px;
  border-radius: 50%;
  flex-shrink: 0;
}
.report-info { flex: 1; min-width: 0; }
.report-title {
  font-size: 13px;
  font-weight: 600;
  color: var(--txt1);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.report-sub {
  font-size: 11px;
  color: var(--txt3);
  margin-top: 2px;
}
.report-tag {
  font-size: 10px;
  font-weight: 600;
  padding: 3px 8px;
  border-radius: 20px;
  white-space: nowrap;
}
.tag-red { background: var(--red-lt); color: var(--red); }
.tag-amb { background: var(--amb-lt); color: var(--amb); }
.tag-grn { background: var(--grn-lt); color: var(--grn); }
.tag-pri { background: var(--pri-lt); color: var(--pri); }
.tag-pur { background: var(--pur-lt); color: var(--pur); }
.report-time {
  font-size: 11px;
  color: var(--txt3);
  flex-shrink: 0;
}

/* ── 활동 피드 ── */
.feed-list { padding: 8px 0; }
.feed-item {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  padding: 8px 20px;
}
.feed-dot {
  width: 8px; height: 8px;
  border-radius: 50%;
  flex-shrink: 0;
  margin-top: 5px;
}
.feed-text {
  font-size: 12px;
  color: var(--txt2);
  line-height: 1.5;
  flex: 1;
}
.feed-text b { color: var(--txt1); font-weight: 600; }
.feed-time {
  font-size: 11px;
  color: var(--txt3);
  flex-shrink: 0;
}

/* ── 차트 영역 ── */
.chart-wrap {
  padding: 20px;
  height: 200px;
  display: flex;
  align-items: flex-end;
  gap: 6px;
}
.bar-group {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
  height: 100%;
  justify-content: flex-end;
}
.bar-label { font-size: 10px; color: var(--txt3); }
.bar {
  width: 100%;
  border-radius: 4px 4px 0 0;
  background: var(--pri-lt);
  position: relative;
  transition: background .15s;
  cursor: pointer;
}
.bar:hover { background: var(--pri); }
.bar.today { background: var(--pri); }

/* ── 스폰서 슬롯 ── */
.slot-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 8px;
  padding: 16px 20px;
}
.slot-item {
  background: var(--bg);
  border-radius: 8px;
  padding: 10px;
  text-align: center;
  border: 1.5px dashed var(--bd);
  cursor: pointer;
  transition: all .15s;
}
.slot-item.filled {
  border: 1.5px solid var(--bd);
  background: var(--card);
  box-shadow: 0 1px 4px rgba(0,0,0,.06);
}
.slot-item:hover { border-color: var(--pri); }
.slot-emoji { font-size: 22px; margin-bottom: 4px; }
.slot-name { font-size: 10px; font-weight: 600; color: var(--txt2); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.slot-tag { font-size: 9px; color: var(--txt3); margin-top: 2px; }
.slot-empty-icon { font-size: 22px; opacity: .3; margin-bottom: 4px; }
.slot-empty-txt { font-size: 10px; color: var(--txt3); }

/* ── 통계 미니 ── */
.mini-stats {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
  padding: 16px 20px;
}
.mini-stat {
  background: var(--bg);
  border-radius: 8px;
  padding: 12px;
}
.mini-num {
  font-size: 20px;
  font-weight: 700;
  color: var(--txt1);
  line-height: 1;
}
.mini-lbl {
  font-size: 11px;
  color: var(--txt3);
  margin-top: 4px;
}
.mini-chg {
  font-size: 11px;
  font-weight: 500;
  margin-top: 4px;
}

/* ── 하단 그리드 ── */
.dash-grid-3 {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 16px;
}

/* ── 공통 유틸 ── */
.flex { display: flex; align-items: center; gap: 8px; }
.ml-auto { margin-left: auto; }
.svg-icon { width: 16px; height: 16px; }
</style>
</head>
<body>

<!-- ── 로그인 화면 ── -->
<div class="login-screen" id="login-screen">
  <div class="login-card">
    <div class="login-logo">M</div>
    <div class="login-title">MODAK Admin</div>
    <div class="login-sub">관리자 계정으로 로그인하세요</div>
    <div class="login-label">이메일</div>
    <input class="login-input" type="email" id="login-email" placeholder="admin@modak.com"
      onkeydown="if(event.key==='Enter')doLogin()"/>
    <div class="login-label">비밀번호</div>
    <input class="login-input" type="password" id="login-pw" placeholder="비밀번호 입력"
      onkeydown="if(event.key==='Enter')doLogin()"/>
    <button class="login-btn" onclick="doLogin()">로그인</button>
    <div class="login-err" id="login-err"></div>
    <div class="login-footer">MODAK Sydney · 관리자 전용 페이지</div>
  </div>
</div>


<!-- ── 사이드바 ── -->
<aside class="sidebar">
  <div class="side-logo">
    <div class="side-logo-mark">M</div>
    <span class="side-logo-text">MODAK</span>
    <span class="side-logo-badge">Admin</span>
  </div>

  <nav class="side-nav">
    <div class="side-section-label">메인</div>

    <div class="nav-item active" onclick="setPage('dashboard')">
      <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
      대시보드
    </div>

    <div class="side-section-label">운영</div>

    <div class="nav-item" onclick="setPage('reports')">
      <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
      신고 관리
      <span class="nav-badge">5</span>
    </div>

    <div class="nav-item" onclick="setPage('members')">
      <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
      회원 관리
    </div>

    <div class="nav-item" onclick="setPage('posts')">
      <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14,2 14,8 20,8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><line x1="10" y1="9" x2="8" y2="9"/></svg>
      게시물 관리
    </div>

    <div class="side-section-label">광고·수익</div>

    <div class="nav-item" onclick="setPage('sponsors')">
      <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polygon points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26"/></svg>
      스폰서 관리
    </div>

    <div class="nav-item" onclick="setPage('deals')">
      <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
      딜·혜택 관리
    </div>

    <div class="nav-item" onclick="setPage('orders')">
      <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
      광고 주문 관리
      <span class="nav-badge amber">2</span>
    </div>

