  const word = FORBIDDEN_WORDS[idx];
  if (!confirm(`"${word}" 금칙어를 삭제하시겠습니까?`)) return;
  FORBIDDEN_WORDS.splice(idx, 1);
  showToast(`🗑 "${word}" 금칙어가 삭제됐습니다`);
  reloadReview();
}

function handleRvAction(id, action) {
  if (!checkWriteAccess()) return;
  const r = REVIEW_ITEMS.find(x=>x.id===id);
  if (!r) return;
  const toasts = { pass:'✅ 게시물이 통과 처리됐습니다', delete:'🗑 게시물이 삭제됐습니다', warn:'⚠️ 작성자에게 경고가 조치됐습니다', ban:'🚫 작성자 계정이 정지됐습니다' };
  if (action === 'pass')   { r.status='passed';  r.action='통과'; }
  if (action === 'delete') { r.status='deleted'; r.action='삭제'; }
  if (action === 'warn')   { r.status='passed';  r.action='통과'; }
  if (action === 'ban')    { r.status='deleted'; r.action='삭제'; }
  rvSelected = null;
  showToast(toasts[action]);
  reloadReview();
}

