        </div>` : ''}
      </div>
      <div style="font-size:12px;font-weight:600;color:var(--txt2);margin-top:4px">신고 내용</div>
      <div class="det-desc">${r.detail}</div>
    </div>
    ${r.status === 'pending' ? `
    <div class="act-btns">
      <button class="act-btn btn-del"   onclick="handleAction('${r.id}','게시물삭제')">게시물 삭제</button>
      <button class="act-btn btn-warn"  onclick="handleAction('${r.id}','경고조치')">경고 조치</button>
      <button class="act-btn btn-ban"   onclick="handleAction('${r.id}','계정정지')">계정 정지</button>
      <button class="act-btn btn-pass"  onclick="handleAction('${r.id}','무혐의')">무혐의 처리</button>
    </div>` : `
    <div style="padding:14px 20px;border-top:1px solid var(--bd)">
      <button class="act-btn btn-pass" style="width:100%" onclick="rSelected=null;reloadReports()">닫기</button>
    </div>`}
  `;
}

function setRFilter(f) {
  rFilter = f;
  rSelected = null;
  reloadReports();
}

function selectReport(id) {
  rSelected = id;
  reloadReports();
}

function handleAction(id, action) {
  const r = REPORTS.find(x => x.id === id);
  if (!r) return;
  const msgs = { '게시물삭제':'게시물을 삭제하시겠습니까?', '경고조치':'이 사용자에게 경고를 보내시겠습니까?', '계정정지':'이 계정을 정지하시겠습니까? 사용자는 즉시 앱 이용이 제한됩니다.', '무혐의':'이 신고를 무혐의로 처리하시겠습니까?' };
  if (!confirm(msgs[action] || '처리하시겠습니까?')) return;
  r.status = 'done';
  r.action = action;
  r.actionAt = '방금';
  // 카운터 업데이트
  const badge = document.querySelector('.nav-item:nth-child(2) .nav-badge');
  if (badge) {
    const cur = parseInt(badge.textContent) - 1;
    if (cur <= 0) badge.remove(); else badge.textContent = cur;
  }
  rFilter = 'done';
  rSelected = id;
  reloadReports();
  showToast(`✅ ${action} 처리 완료`);
}

function reloadReports() {
  document.getElementById('page-content').innerHTML = renderReports();
}

function showToast(msg) {
  const t = document.createElement('div');
  t.style.cssText = 'position:fixed;bottom:28px;left:50%;transform:translateX(-50%);background:#101828;color:#fff;padding:10px 20px;border-radius:8px;font-size:13px;font-weight:600;z-index:9999;pointer-events:none;opacity:0;transition:opacity .2s';
  t.textContent = msg;
  document.body.appendChild(t);
  requestAnimationFrame(() => { t.style.opacity = '1'; });
  setTimeout(() => { t.style.opacity = '0'; setTimeout(() => t.remove(), 200); }, 2500);
}

function setPage(page) {
  // ── 비로그인 차단 (대시보드는 허용)
  if (!_session && page !== 'dashboard') {
    showLoginScreen();
    showToast('🔒 로그인이 필요합니다');
    return;
  }
  document.querySelectorAll('.nav-item').forEach(el => el.classList.remove('active'));
  if (event && event.currentTarget) event.currentTarget.classList.add('active');
  _currentPage = page;
  const name = pageNames[page] || page;
  document.getElementById('page-title').textContent = name;
  document.getElementById('bc-page').textContent = name;

  if (page === 'dashboard') {
    location.reload();
  } else if (page === 'reports') {
    rFilter = 'pending'; rSelected = null;
    document.getElementById('page-content').innerHTML = renderReports();
  } else if (page === 'members') {
    mFilter = 'all'; mSearch = ''; mSelected = null;
    document.getElementById('page-content').innerHTML = renderMembers();
  } else if (page === 'posts') {
    pCat = 'all'; pSearch = ''; pSelected = null;
    document.getElementById('page-content').innerHTML = renderPosts();
  } else if (page === 'sponsors') {
    spSelected = null; spMode = 'list';
    document.getElementById('page-content').innerHTML = renderSponsors();
  } else if (page === 'deals') {
    dlSelected = null; dlMode = 'list'; dlFilter = 'all';
    document.getElementById('page-content').innerHTML = renderDeals();
  } else if (page === 'orders') {
    orSelected = null; orFilter = 'all';
    document.getElementById('page-content').innerHTML = renderOrders();
  } else if (page === 'notices') {
    ncSelected = null; ncMode = 'list';
    document.getElementById('page-content').innerHTML = renderNotices();
  } else if (page === 'admin') {
    adSelected = null; adMode = 'list';
    document.getElementById('page-content').innerHTML = renderAdminPage();
  } else if (page === 'stats') {
    stTab = 'users';
    document.getElementById('page-content').innerHTML = renderStats();
  } else if (page === 'push') {
    pushTab = 'compose';
    document.getElementById('page-content').innerHTML = renderPush();
  } else if (page === 'review') {
    rvFilter = 'pending'; rvSelected = null;
    document.getElementById('page-content').innerHTML = renderReview();
  } else if (page === 'inquiry') {
    iqSelected = null; iqFilter = 'all';
    document.getElementById('page-content').innerHTML = renderInquiry();
  } else if (page === 'region') {
    document.getElementById('page-content').innerHTML = renderRegion();
  } else {
    document.getElementById('page-content').innerHTML =
      `<div style="display:flex;flex-direction:column;align-items:center;justify-content:center;height:400px;gap:16px;color:var(--txt3)">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><rect x="3" y="3" width="18" height="18" rx="3"/><path d="M9 9h6M9 12h6M9 15h4"/></svg>
        <div style="font-size:16px;font-weight:600;color:var(--txt2)">${name}</div>
        <div style="font-size:13px">다음 단계에서 개발됩니다</div>
      </div>`;
  }
}
// 페이지 로드 시 즉시 실행
(function() {
  renderSideUser();
  updateNotifDot();
})();
</script>
</body>
</html>
