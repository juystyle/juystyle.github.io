function handleOrAction(id, action) {
  if (!checkWriteAccess()) return;
  const o = ORDERS.find(x=>x.id===id);
  if (!o) return;
  const msgs = {
    approve:    `${o.sponsor} 주문을 승인하시겠습니까?`,
    reject:     `${o.sponsor} 주문을 거절하시겠습니까?`,
    notify:     `${o.sponsor}에 광고 만료 연장 안내를 발송하시겠습니까?`,
    extend:     null,
    refund:     `${o.sponsor} 주문을 환불 처리하시겠습니까? ($${o.fee} 환불)`,
    reactivate: `${o.sponsor} 재계약을 처리하시겠습니까?`,
  };
  if (msgs[action] && !confirm(msgs[action])) return;

  if (action === 'approve')    { o.status = 'approved'; showToast('✅ 광고가 승인됐습니다'); }
  if (action === 'reject')     { o.status = 'expired';  showToast('❌ 주문이 거절됐습니다'); }
  if (action === 'notify')     { showToast('📨 연장 안내가 발송됐습니다'); return; }
  if (action === 'refund')     { o.status = 'refunded'; showToast(`💰 $${o.fee} 환불 처리됐습니다`); }
  if (action === 'reactivate') { o.status = 'approved'; showToast('✅ 재계약이 처리됐습니다'); }
  if (action === 'extend') {
    const days = parseInt(prompt('연장할 일수를 입력하세요:', '30'));
    if (!days || isNaN(days)) return;
    const parts  = o.period.split(' ~ ');
    const newEnd = new Date(parts[1]);
    newEnd.setDate(newEnd.getDate() + days);
    o.period = parts[0] + ' ~ ' + newEnd.toISOString().split('T')[0];
    o.status = 'approved';
    showToast(`✅ ${days}일 연장됐습니다`);
  }
  reloadOrders();
}

function saveOrNote(id) {
  const o = ORDERS.find(x=>x.id===id);
  const input = document.getElementById('or-note-' + id);
  if (!o || !input || !input.value.trim()) return;
  o.note = input.value.trim();
  showToast('📝 메모가 저장됐습니다');
  reloadOrders();
}

