function getFilteredMembers() {
  return MEMBERS.filter(m => {
    if (mFilter === 'active')    return m.status === 'active';
    if (mFilter === 'suspended') return m.status === 'suspended';
    if (mFilter === 'verified')  return m.auth === 'verified';
    return true;
  }).filter(m => {
    if (!mSearch) return true;
    const q = mSearch.toLowerCase();
    return m.name.toLowerCase().includes(q) || m.email.toLowerCase().includes(q) || (m.region||'').toLowerCase().includes(q);
  });
}

