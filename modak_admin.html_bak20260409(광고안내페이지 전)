    ncSelected = id;
  } else {
    const newN = { id:'n'+(NOTICES.length+1).toString().padStart(3,'0'), type, title, region, popup, pinned, status, publishDate:date, expireDate:expire, views:0, author:'Juyoung', body };
    NOTICES.unshift(newN);
    ncSelected = newN.id;
  }
  ncMode = 'list';
  showToast(status==='publish' ? '✅ 공지가 발행됐습니다' : '📝 초안이 저장됐습니다');
  reloadNotices();
}

function handleNcAction(id, action) {
  if (!checkWriteAccess()) return;
  const n = NOTICES.find(x=>x.id===id);
  if (!n) return;
  if (action === 'publish')   { n.status='published'; showToast('✅ 공지가 발행됐습니다'); }
  if (action === 'unpublish') { n.status='draft';     showToast('↩️ 공지가 내려졌습니다'); }
  if (action === 'togglePin') {
    n.pinned = !n.pinned;
    showToast(n.pinned ? '📌 상단 고정됐습니다' : '📌 고정이 해제됐습니다');
  }
  if (action === 'delete') {
    if (!confirm(`"${n.title}" 공지를 삭제하시겠습니까?`)) return;
    NOTICES.splice(NOTICES.findIndex(x=>x.id===id), 1);
    ncSelected = null;
    showToast('🗑 공지가 삭제됐습니다');
  }
  reloadNotices();
}

function editNc(id)     { ncSelected = id; ncMode = 'edit'; reloadNotices(); }
function selectNc(id)   { ncSelected = id; ncMode = 'list'; reloadNotices(); }
