      <div style="display:flex;gap:6px;flex-wrap:wrap;justify-content:center">
        <span class="report-tag ${statusColor[s.status]}">${statusLabel[s.status]}</span>
        ${s.tag?`<span class="report-tag tag-amb">${s.tag}</span>`:''}
        ${s.ver?`<span class="report-tag tag-grn">검증완료 ✓</span>`:`<span class="report-tag tag-pur">미검증</span>`}
      </div>
      ${days > 0 ? `
      <div style="background:${days<=7?'var(--red-lt)':days<=14?'var(--amb-lt)':'var(--grn-lt)'};border-radius:20px;padding:4px 14px;font-size:12px;font-weight:700;color:${days<=7?'var(--red)':days<=14?'var(--amb)':'var(--grn)'}">
        ${days <= 0 ? '만료됨' : `D-${days} 남음`}
      </div>` : ''}
    </div>
    <div class="sp-det-rows">
      <div class="sp-d-row"><span class="sp-d-lbl">플랜</span><span class="sp-d-val" style="font-weight:600">${s.plan} · $${s.fee}/월</span></div>
      <div class="sp-d-row"><span class="sp-d-lbl">광고 기간</span><span class="sp-d-val">${s.startDate} ~ ${s.endDate}</span></div>
      <div class="sp-d-row"><span class="sp-d-lbl">연락처</span><span class="sp-d-val">${s.phone || '미등록'}</span></div>
      <div class="sp-d-row"><span class="sp-d-lbl">주소</span><span class="sp-d-val" style="font-size:12px">${s.addr}</span></div>
      <div class="sp-d-row"><span class="sp-d-lbl">업체 소개</span><span class="sp-d-val" style="font-size:12px;color:var(--txt2)">${s.desc}</span></div>
    </div>
    <div class="sp-acts">
      <button class="act-btn btn-pass" style="border:1px solid var(--bd)" onclick="handleSpAction('${s.id}','extend')">기간 연장</button>
      <button class="act-btn ${s.ver?'btn-pass':'btn-warn'}" onclick="handleSpAction('${s.id}','verify')" style="${s.ver?'border:1px solid var(--bd)':''}">${s.ver?'검증 취소':'검증 완료'}</button>
      ${s.tag==='Premium'
        ? `<button class="act-btn btn-pass" onclick="handleSpAction('${s.id}','tag-new')" style="border:1px solid var(--bd)">NEW 태그</button>`
        : `<button class="act-btn btn-pass" onclick="handleSpAction('${s.id}','tag-premium')" style="border:1px solid var(--bd)">Premium 태그</button>`}
      <button class="act-btn btn-del" onclick="handleSpAction('${s.id}','delete')">업체 삭제</button>
    </div>
  </div>`;
}

function handleSpAction(id, action) {
  if (!checkWriteAccess()) return;
  const s = SPONSORS.find(x=>x.id===id);
  if (!s) return;
  if (action === 'extend') {
    const days = parseInt(prompt('연장할 일수를 입력하세요:', '30'));
    if (!days || isNaN(days)) return;
    const cur = new Date(s.endDate);
    cur.setDate(cur.getDate() + days);
    s.endDate = cur.toISOString().split('T')[0];
    s.status  = 'active';
    showToast(`✅ ${days}일 연장됐습니다 (${s.endDate}까지)`);
  }
  if (action === 'verify')      { s.ver = !s.ver; showToast(s.ver ? '✅ 검증 완료 처리됐습니다' : '↩️ 검증이 취소됐습니다'); }
  if (action === 'tag-premium') { s.tag = 'Premium'; showToast('⭐ Premium 태그가 설정됐습니다'); }
  if (action === 'tag-new')     { s.tag = 'NEW';     showToast('🆕 NEW 태그가 설정됐습니다'); }
  if (action === 'delete') {
    if (!confirm(`${s.nm} 업체를 삭제하시겠습니까?`)) return;
    SPONSORS.splice(SPONSORS.findIndex(x=>x.id===id), 1);
    spSelected = null;
    showToast('🗑 업체가 삭제됐습니다');
  }
  reloadSponsors();
}

