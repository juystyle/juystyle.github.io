function selectRole(role) {
  ['super','manager','viewer'].forEach(r => {
    const el = document.getElementById('role-card-' + r);
    if (el) el.classList.toggle('on', r === role);
  });
  const inp = document.getElementById('inv-role');
  if (inp) inp.value = role;
}

function submitInvite() {
  if (!checkWriteAccess("관리자 초대를")) return;
  const name  = document.getElementById('inv-name')?.value?.trim();
  const email = document.getElementById('inv-email')?.value?.trim();
  const role  = document.getElementById('inv-role')?.value || 'viewer';
  if (!name || !email) { alert('이름과 이메일을 입력해주세요'); return; }
  if (!email.includes('@')) { alert('올바른 이메일을 입력해주세요'); return; }
  const initials = name.slice(0,2).toUpperCase();
  const newAdmin = {
    id:         'a' + (ADMINS.length+1).toString().padStart(3,'0'),
    name, email, role,
    status:     'inactive',
    joinDate:   new Date().toISOString().split('T')[0],
    lastLogin:  '미접속',
    loginCount: 0,
    twoFA:      false,
    avatar:     initials,
    logs:       [{ action:'초대 이메일 발송됨', time:'방금' }],
  };
  ADMINS.push(newAdmin);
  adMode     = 'list';
  adSelected = newAdmin.id;
  showToast(`📨 ${email}로 초대 이메일을 발송했습니다`);
  reloadAdmin();
}

function handleAdAction(id, action) {
  if (!checkWriteAccess()) return;
  const a = ADMINS.find(x=>x.id===id);
  if (!a) return;
  if (action === 'changeRole') {
    const roles  = ['super','manager','viewer'];
    const cur    = roles.indexOf(a.role);
    const choice = prompt(`권한을 선택하세요:\n1. 슈퍼 관리자\n2. 관리자\n3. 읽기전용\n\n현재: ${ROLE_LABEL[a.role]}`, cur+1);
    const idx    = parseInt(choice) - 1;
    if (idx < 0 || idx >= roles.length || isNaN(idx)) return;
    a.role = roles[idx];
    showToast(`✅ ${a.name}의 권한이 ${ROLE_LABEL[a.role]}(으)로 변경됐습니다`);
  }
  if (action === 'deactivate') {
    if (!confirm(`${a.name} 계정을 비활성화하시겠습니까?`)) return;
    a.status = 'inactive';
    showToast(`⛔ ${a.name} 계정이 비활성화됐습니다`);
  }
  if (action === 'activate') {
    a.status = 'active';
    showToast(`✅ ${a.name} 계정이 활성화됐습니다`);
  }
  if (action === 'resetPw') {
    if (!confirm(`${a.name}의 비밀번호를 초기화하고 이메일을 발송하시겠습니까?`)) return;
    showToast(`📨 ${a.email}로 임시 비밀번호가 발송됐습니다`);
    return;
  }
  if (action === 'delete') {
    if (!confirm(`${a.name} 계정을 삭제하시겠습니까? 이 작업은 되돌릴 수 없습니다.`)) return;
    ADMINS.splice(ADMINS.findIndex(x=>x.id===id), 1);
    adSelected = null;
    showToast(`🗑 ${a.name} 계정이 삭제됐습니다`);
  }
  reloadAdmin();
}

