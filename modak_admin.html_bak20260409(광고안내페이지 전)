function closeGlobalSearch() {
  const el = document.getElementById('gs-overlay');
  if (el) el.remove();
}

function runGlobalSearch(q) {
  const res = document.getElementById('gs-results');
  if (!res) return;
  q = q.trim().toLowerCase();
  if (!q) { res.innerHTML = '<div style="padding:20px;text-align:center;color:var(--txt3);font-size:13px">검색어를 입력하세요</div>'; return; }

  const results = [];

  // 회원 검색
  MEMBERS.filter(m => m.name.toLowerCase().includes(q) || m.email.toLowerCase().includes(q)).slice(0,3).forEach(m => {
    results.push({ icon:'👤', category:'회원', title:m.name, sub:m.email, page:'members', id:m.id });
  });
  // 게시물 검색
  POSTS.filter(p => p.title.toLowerCase().includes(q) || p.author.toLowerCase().includes(q)).slice(0,3).forEach(p => {
    results.push({ icon:'📄', category:'게시물', title:p.title, sub:p.author+' · '+p.region, page:'posts', id:p.id });
  });
  // 신고 검색
  REPORTS.filter(r => r.title.toLowerCase().includes(q) || r.reporter.toLowerCase().includes(q)).slice(0,2).forEach(r => {
    results.push({ icon:'🚨', category:'신고', title:r.title, sub:'신고자: '+r.reporter, page:'reports', id:r.id });
  });
  // 스폰서 검색
  SPONSORS.filter(s => s.nm.toLowerCase().includes(q)).slice(0,2).forEach(s => {
    results.push({ icon:'⭐', category:'스폰서', title:s.nm, sub:s.plan+' · '+s.addr.split(',')[0], page:'sponsors', id:s.id });
  });
  // 공지 검색
  NOTICES.filter(n => n.title.toLowerCase().includes(q)).slice(0,2).forEach(n => {
    results.push({ icon:'📢', category:'공지', title:n.title, sub:n.publishDate+' · '+n.region, page:'notices', id:n.id });
  });

  if (results.length === 0) {
    res.innerHTML = `<div style="padding:30px;text-align:center;color:var(--txt3);font-size:13px">"${q}"에 대한 결과가 없습니다</div>`;
    return;
  }

  const catColors = { '회원':'var(--pri)', '게시물':'var(--grn)', '신고':'var(--red)', '스폰서':'var(--amb)', '공지':'var(--pur)' };
  res.innerHTML = results.map((r,i) => `
    <div onclick="goToSearchResult('${r.page}','${r.id}')"
      style="display:flex;align-items:center;gap:12px;padding:10px 20px;cursor:pointer;transition:background .1s"
      onmouseenter="this.style.background='#F5F7FF'" onmouseleave="this.style.background=''">
      <div style="width:32px;height:32px;border-radius:8px;background:#F1F5F9;display:flex;align-items:center;justify-content:center;font-size:15px;flex-shrink:0">${r.icon}</div>
      <div style="flex:1;min-width:0">
        <div style="font-size:13px;font-weight:600;color:var(--txt1);white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${r.title}</div>
        <div style="font-size:11px;color:var(--txt3);margin-top:1px">${r.sub}</div>
      </div>
      <span style="font-size:10px;font-weight:700;padding:2px 8px;border-radius:10px;background:#F1F5F9;color:${catColors[r.category]};white-space:nowrap">${r.category}</span>
    </div>`).join('');
}

