function toggleRegion(id) {
  if (!checkWriteAccess('지역 설정을')) return;
  const r = REGIONS.find(x=>x.id===id);
  if (!r) return;
  const wasActive = r.status==='active';
  if (wasActive && !confirm(`${r.name} 지역을 OFF하시겠습니까? 해당 지역 사용자는 서비스를 이용할 수 없게 됩니다.`)) return;
  r.status = wasActive ? 'planned' : 'active';
  if (!wasActive) { r.launchDate = new Date().toISOString().split('T')[0]; }
  showToast(wasActive ? `⛔ ${r.name} 지역이 비활성화됐습니다` : `✅ ${r.name} 지역이 활성화됐습니다`);
  reloadRegion();
}

function toggleFlag(id) {
  if (!checkWriteAccess('기능 설정을')) return;
  const f = FEATURE_FLAGS.find(x=>x.id===id);
  if (!f) return;
  if (f.enabled && !confirm(`${f.name} 기능을 비활성화하시겠습니까?`)) return;
  f.enabled = !f.enabled;
  showToast(f.enabled ? `✅ ${f.name} 기능이 활성화됐습니다` : `⛔ ${f.name} 기능이 비활성화됐습니다`);
  reloadRegion();
}

function addRegion() {
  if (!checkWriteAccess('지역 추가를')) return;
  const name = prompt('새 지역 이름을 입력하세요:', 'Adelaide CBD');
  if (!name?.trim()) return;
  const state = prompt('주(State)를 입력하세요:', 'SA');
  if (!state?.trim()) return;
  const date = prompt('오픈 예정일:', '2026-01-01');
  REGIONS.push({
    id: 'rg'+(REGIONS.length+1), name: name.trim(), state: state.trim().toUpperCase(),
    status:'planned', members:0, posts:0,
    launchDate: date||'2026-01-01',
    color: ['#6366F1','#EC4899','#14B8A6','#EAB308'][REGIONS.length%4]
  });
  showToast(`✅ ${name} 지역이 추가됐습니다`);
  reloadRegion();
}

