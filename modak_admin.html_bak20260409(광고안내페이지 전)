  if (_session && _session.role === 'viewer') {
    showToast('🔒 읽기전용 계정은 ' + (actionLabel||'이 작업을') + ' 할 수 없습니다');
    return false;
  }
  return true;
}
function doLogin() {
  const email = document.getElementById('login-email')?.value?.trim();
  const pw    = document.getElementById('login-pw')?.value;
  const err   = document.getElementById('login-err');

  if (!email || !pw) {
    err.textContent = '이메일과 비밀번호를 입력해주세요';
    return;
  }

  // 로딩 효과
  const btn = document.querySelector('.login-btn');
  if (btn) { btn.textContent = '로그인 중...'; btn.disabled = true; }

  setTimeout(() => {
    const account = ADMIN_ACCOUNTS.find(a => a.email === email && a.pw === pw);
    if (!account) {
      err.textContent = '이메일 또는 비밀번호가 올바르지 않습니다';
      if (btn) { btn.textContent = '로그인'; btn.disabled = false; }
      const inp = document.getElementById('login-pw');
      if (inp) { inp.value = ''; inp.focus(); }
      return;
    }

    // 로그인 성공
    _session = { ...account };
    const screen = document.getElementById('login-screen');
    if (screen) {
      screen.style.opacity = '0';
      screen.style.transition = 'opacity .3s';
      setTimeout(() => { screen.style.display = 'none'; }, 300);
    }
    renderSideUser();
    updateNotifDot();
    showToast(`👋 환영합니다, ${account.name}님!`);

    // ACCESS_LOG에 로그인 기록 추가
    if (typeof ACCESS_LOG !== 'undefined') {
      ACCESS_LOG.unshift({ admin: account.name, action: '로그인', ip: '203.0.113.1', time: '방금' });
    }
  }, 600);
}

function doLogout() {
  if (!confirm('로그아웃 하시겠습니까?')) return;

  // 설정 패널 닫기
  document.getElementById('settings-panel')?.remove();

  // 화면 초기화
  const screen = document.getElementById('login-screen');
  if (screen) {
    // 이메일·비밀번호 초기화
    const em = document.getElementById('login-email');
    const pw = document.getElementById('login-pw');
    const er = document.getElementById('login-err');
    if (em) em.value = '';
    if (pw) pw.value = '';
    if (er) er.textContent = '';
    const btn = document.querySelector('.login-btn');
    if (btn) { btn.textContent = '로그인'; btn.disabled = false; }

    screen.style.display = 'flex';
    screen.style.opacity = '0';
    setTimeout(() => { screen.style.opacity = '1'; screen.style.transition = 'opacity .3s'; }, 50);
  }

  _session = null;
  renderSideUser();
}

