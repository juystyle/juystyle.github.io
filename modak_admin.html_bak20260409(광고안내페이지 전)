function submitSpAdd() {
  if (!checkWriteAccess("업체 등록을")) return;
  const nm    = document.getElementById('sp-nm')?.value?.trim();
  const plan  = document.getElementById('sp-plan')?.value;
  const start = document.getElementById('sp-start')?.value;
  const end   = document.getElementById('sp-end')?.value;
  if (!nm || !plan || !start || !end) { alert('필수 항목을 입력해주세요 (업체명, 플랜, 기간)'); return; }
  const newSp = {
    id:        's' + (SPONSORS.length + 1),
    nm,
    e:         document.getElementById('sp-e')?.value || '🏪',
    tag:       document.getElementById('sp-tag')?.value || '',
    ring:      ['#6366F1','#8B5CF6'],
    phone:     document.getElementById('sp-phone')?.value || '',
    addr:      document.getElementById('sp-addr')?.value || '',
    desc:      document.getElementById('sp-desc')?.value || '',
    startDate: start,
    endDate:   end,
    plan,
    fee:       plan.includes('Premium') ? 350 : 150,
    status:    'active',
    ver:       document.getElementById('sp-ver')?.value === 'true',
  };
  SPONSORS.push(newSp);
  spMode = 'list';
  spSelected = newSp.id;
  showToast('✅ 업체가 등록됐습니다');
  reloadSponsors();
}

function renderSpDetail(s) {
  const days = getDaysLeft(s.endDate);
  const statusLabel = { active:'진행중', expiring:'만료임박', expired:'만료됨' };
  const statusColor = { active:'tag-grn', expiring:'tag-amb', expired:'tag-pur' };
  return `
  <div class="det-sp">
    <div class="det-sp-top">
      <div class="det-sp-ring" style="background:linear-gradient(135deg,${s.ring[0]},${s.ring[1]})">${s.e}</div>
