  if (inp) inp.value = region;
  const prev = document.getElementById('preview-region');
  if (prev) prev.textContent = region;
}

function updatePushPreview() {
  const title = document.getElementById('push-title')?.value || '알림 제목이 여기에 표시됩니다';
  const body  = document.getElementById('push-body')?.value  || '알림 내용이 여기에 표시됩니다';
  const pt    = document.getElementById('preview-title');
  const pb    = document.getElementById('preview-body');
  if (pt) pt.textContent = title || '알림 제목이 여기에 표시됩니다';
  if (pb) pb.textContent = body  || '알림 내용이 여기에 표시됩니다';
}

function togglePushSchedule(el) {
  const sc = document.getElementById('push-schedule');
  if (sc) sc.style.display = el.value === 'schedule' ? 'block' : 'none';
}

function sendPush(mode) {
  const title  = document.getElementById('push-title')?.value?.trim();
  const body   = document.getElementById('push-body')?.value?.trim();
  const region = document.getElementById('push-region')?.value || '전체';
  if (!title || !body) { alert('제목과 내용을 입력해주세요'); return; }
  if (mode === 'test') {
    showToast('📱 테스트 알림이 내 기기로 발송됐습니다');
    return;
  }
  const isScheduled = document.querySelector('input[name="push-time"]:checked')?.value === 'schedule';
  const newPush = {
    id:       'p' + (PUSH_HISTORY.length+1).toString().padStart(3,'0'),
    title, body,
    target:   region,
    sent:     isScheduled ? 0 : 1284,
    opened:   isScheduled ? 0 : 0,
    openRate: isScheduled ? 0 : 0,
    sentAt:   new Date().toLocaleString('ko-KR').replace(/\. /g,'-').replace('.',':').slice(0,16),
    status:   isScheduled ? 'scheduled' : 'sent',
  };
  PUSH_HISTORY.unshift(newPush);
  pushTab = 'history';
  showToast(isScheduled ? '⏰ 알림이 예약됐습니다' : '📨 푸시 알림이 발송됐습니다');
  reloadPush();
}

function setPushTab(tab) { pushTab = tab; reloadPush(); }
