let pCat='all', pSearch='', pSelected=null;

function getFilteredPosts(){
  return POSTS.filter(p=>{
    if(pCat!=='all'&&p.cat!==pCat)return false;
    if(pSearch){const q=pSearch.toLowerCase();if(!p.title.toLowerCase().includes(q)&&!p.author.toLowerCase().includes(q)&&!p.region.toLowerCase().includes(q))return false;}
    return true;
  });
}

