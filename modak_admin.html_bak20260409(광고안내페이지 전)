      <span style="font-size:11px;color:var(--txt3);margin-left:auto">${q.created}</span>
    </div>
    <div class="iq-det-ttl">${q.title}</div>
  </div>
  <div class="iq-d-rows">
    <div class="iq-d-row">
      <span class="iq-d-lbl">작성자</span>
      <span class="iq-d-val">${q.author}</span>
    </div>
    <div class="iq-d-row">
      <span class="iq-d-lbl">이메일</span>
      <a href="mailto:${q.email}" style="font-size:13px;color:var(--pri);flex:1">${q.email}</a>
    </div>
  </div>
  <div class="iq-reply">
    <div class="iq-reply-lbl">답변</div>
    ${q.status==='replied' ? `
      <div class="iq-reply-answered">${q.reply}</div>
      <button class="act-btn btn-pass" style="width:100%;border:1px solid var(--bd);font-size:12px" onclick="editIqReply('${q.id}')">답변 수정</button>
    ` : `
      <textarea class="iq-reply-box" id="iq-reply-${q.id}" placeholder="답변 내용을 입력하세요..."></textarea>
      <div style="display:flex;gap:8px;margin-top:8px">
        <button class="act-btn btn-pass" style="flex:1;border:1px solid var(--bd);font-size:12px" onclick="submitIqReply('${q.id}','draft')">임시 저장</button>
        <button class="act-btn" style="flex:2;background:var(--pri);color:#fff;border:none;border-radius:var(--r-sm);cursor:pointer;font-size:12px;font-weight:600" onclick="submitIqReply('${q.id}','send')">답변 발송</button>
      </div>`}
  </div>`;
}

function submitIqReply(id, mode) {
  if (!checkWriteAccess('답변 발송을')) return;
  const q    = INQUIRIES.find(x=>x.id===id);
  const text = document.getElementById('iq-reply-'+id)?.value?.trim();
  if (!q || !text) { alert('답변 내용을 입력해주세요'); return; }
  q.reply  = text;
  q.status = 'replied';
  showToast(mode==='send' ? '📨 답변이 발송됐습니다' : '📝 임시 저장됐습니다');
  reloadInquiry();
}

function editIqReply(id) {
  const q = INQUIRIES.find(x=>x.id===id);
  if (!q) return;
  q.status = 'pending';
  reloadInquiry();
}

function setIqFilter(f) { iqFilter=f; iqSelected=null; reloadInquiry(); }
function selectIq(id)   { iqSelected=id; reloadInquiry(); }
function reloadInquiry(){ document.getElementById('page-content').innerHTML=renderInquiry(); }

