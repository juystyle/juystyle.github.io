  const start = document.getElementById('dl-start')?.value;
  const end   = document.getElementById('dl-end')?.value;
  if (!nm || !code || !start || !end) { alert('필수 항목을 입력해주세요 (제목, 쿠폰코드, 기간)'); return; }
  const newDl = {
    id:        'd' + (DEALS.length + 1),
    nm,
    e:         document.getElementById('dl-e')?.value || '🎁',
    cat:       document.getElementById('dl-cat')?.value || '기타',
    sponsor:   document.getElementById('dl-sponsor')?.value || '',
    discount:  parseInt(document.getElementById('dl-disc')?.value) || 0,
    type:      document.getElementById('dl-type')?.value || '%',
    price:     document.getElementById('dl-price')?.value || '',
    code,
    region:    document.getElementById('dl-region')?.value || '전체',
    startDate: start,
    endDate:   end,
    used:      0,
    limit:     parseInt(document.getElementById('dl-limit')?.value) || 100,
    status:    'active',
    desc:      document.getElementById('dl-desc')?.value || '',
  };
  DEALS.push(newDl);
  dlMode = 'list';
  dlSelected = newDl.id;
  showToast('✅ 딜이 등록됐습니다');
  reloadDeals();
}

function handleDlAction(id, action) {
  if (!checkWriteAccess()) return;
  const d = DEALS.find(x=>x.id===id);
  if (!d) return;
  if (action === 'extend') {
    const days = parseInt(prompt('연장할 일수를 입력하세요:', '30'));
    if (!days || isNaN(days)) return;
    const cur = new Date(d.endDate);
    cur.setDate(cur.getDate() + days);
    d.endDate = cur.toISOString().split('T')[0];
    d.status  = 'active';
    showToast(`✅ ${days}일 연장됐습니다 (${d.endDate}까지)`);
  }
  if (action === 'limit') {
    const newLimit = parseInt(prompt('새 사용 한도를 입력하세요:', d.limit));
    if (!newLimit || isNaN(newLimit)) return;
    d.limit = newLimit;
    showToast(`✅ 사용 한도가 ${newLimit}회로 변경됐습니다`);
  }
  if (action === 'pause')  { d.status = 'expired'; showToast('⏸ 딜이 일시 중단됐습니다'); }
  if (action === 'resume') { d.status = 'active';  showToast('▶️ 딜이 재개됐습니다'); }
  if (action === 'delete') {
    if (!confirm(`"${d.nm}" 딜을 삭제하시겠습니까?`)) return;
    DEALS.splice(DEALS.findIndex(x=>x.id===id), 1);
    dlSelected = null;
    showToast('🗑 딜이 삭제됐습니다');
  }
  reloadDeals();
}

function setDlFilter(f) { dlFilter = f; dlSelected = null; reloadDeals(); }
function selectDl(id)   { dlSelected = id; dlMode = 'list'; reloadDeals(); }
