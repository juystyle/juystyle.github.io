function handlePostAction(id,action){
  const p=POSTS.find(x=>x.id===id); if(!p)return;
  const msgs={hide:'이 게시물을 숨기시겠습니까?',show:'게시 상태로 복구하시겠습니까?',done:'거래완료 처리하시겠습니까?',undone:'완료 처리를 취소하시겠습니까?',delete:'영구 삭제하시겠습니까? 되돌릴 수 없습니다.'};
  if(!confirm(msgs[action]))return;
  const toasts={hide:'🙈 게시물이 숨김 처리됐습니다',show:'✅ 게시물이 복구됐습니다',done:'✅ 거래완료 처리됐습니다',undone:'↩️ 완료 처리가 취소됐습니다',delete:'🗑 게시물이 삭제됐습니다'};
  if(action==='hide'){p.status='hidden';}
  if(action==='show'){p.status='active';}
  if(action==='done'){p.status='done';p.done=true;}
  if(action==='undone'){p.status='active';p.done=false;}
  if(action==='delete'){POSTS.splice(POSTS.findIndex(x=>x.id===id),1);pSelected=null;}
  showToast(toasts[action]);
  reloadPosts();
}

