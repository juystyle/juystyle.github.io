}

function handleMemberAction(id, action) {
  if (!checkWriteAccess()) return;
  const m = MEMBERS.find(x => x.id === id);
  if (!m) return;
  const msgs = {
    warn:      `${m.name}님에게 경고를 조치하시겠습니까?`,
    suspend:   `${m.name}님의 계정을 정지하시겠습니까? 즉시 앱 이용이 제한됩니다.`,
    unsuspend: `${m.name}님의 계정 정지를 해제하시겠습니까?`,
    delete:    `${m.name}님을 탈퇴 처리하시겠습니까? 이 작업은 되돌릴 수 없습니다.`
  };
  if (!confirm(msgs[action])) return;
  if (action === 'warn')      { m.warning++; showToast(`⚠️ ${m.name}님에게 경고가 조치됐습니다`); }
  if (action === 'suspend')   { m.status = 'suspended'; showToast(`🚫 ${m.name}님 계정이 정지됐습니다`); }
  if (action === 'unsuspend') { m.status = 'active'; showToast(`✅ ${m.name}님 계정 정지가 해제됐습니다`); }
  if (action === 'delete')    { MEMBERS.splice(MEMBERS.findIndex(x=>x.id===id),1); mSelected=null; showToast(`🗑 ${m.name}님이 탈퇴 처리됐습니다`); }
  reloadMembers();
}

function setMFilter(f) { mFilter = f; mSelected = null; reloadMembers(); }
function selectMember(id) { mSelected = id; reloadMembers(); }
function reloadMembers() { document.getElementById('page-content').innerHTML = renderMembers(); }

